# SpookFi — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ─── Alpaca API ───────────────────────────────────────────────────────────────
# Get from: https://app.alpaca.markets/paper-trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Use paper-api for testing, live-api for real money
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram, create a bot, copy the token
TELEGRAM_BOT_TOKEN=
# 2. Start your bot, then message @userinfobot to get your chat ID
TELEGRAM_CHAT_ID=
